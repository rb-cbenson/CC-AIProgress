{
  "version": "1.0",
  "lastUpdated": "2026-03-27",
  "description": "Trust and security scoring framework for AI tools",
  "scoringDimensions": [
    {
      "name": "Company Stability",
      "weight": 0.15,
      "description": "Funding, team, revenue, years operating"
    },
    {
      "name": "Code Transparency",
      "weight": 0.15,
      "description": "Open source, license type, auditability"
    },
    {
      "name": "Security Track Record",
      "weight": 0.15,
      "description": "Past incidents, response quality, vuln disclosure"
    },
    {
      "name": "Data Handling",
      "weight": 0.15,
      "description": "What data accessed, storage, retention, encryption"
    },
    {
      "name": "Dependency Chain",
      "weight": 0.1,
      "description": "Dependencies audited, pinned, SBOM available"
    },
    {
      "name": "Community & Adoption",
      "weight": 0.1,
      "description": "GitHub stars, enterprise adoption, reviews"
    },
    {
      "name": "Permission Scope",
      "weight": 0.1,
      "description": "Least privilege, justified access requests"
    },
    {
      "name": "Independent Audits",
      "weight": 0.05,
      "description": "Third-party audits, SOC2, pen tests"
    },
    {
      "name": "Incident Recovery",
      "weight": 0.05,
      "description": "How past incidents were handled"
    }
  ],
  "tiers": [
    {
      "range": "80-100",
      "name": "TRUSTED",
      "action": "Use normally. Monitor for changes."
    },
    {
      "range": "60-79",
      "name": "USE WITH CAUTION",
      "action": "Sandbox. No sensitive data."
    },
    {
      "range": "40-59",
      "name": "ELEVATED RISK",
      "action": "Isolated environments only."
    },
    {
      "range": "20-39",
      "name": "HIGH RISK",
      "action": "Avoid unless fully sandboxed."
    },
    {
      "range": "0-19",
      "name": "AVOID",
      "action": "Do not install. Remove if present."
    }
  ],
